# ── anywork4me environment ───────────────────────────────────────────────
# Copy to `.env.local` for local dev, and set the same keys in Vercel.

# Which backend the data layer uses: "mock" (default, in-memory) or "supabase".
NEXT_PUBLIC_DATA_BACKEND=supabase

# From your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key — SERVER ONLY. Never expose to the browser, never prefix with
# NEXT_PUBLIC_. Used by API routes for writes (registration).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key
