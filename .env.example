# ── anywork4me environment ───────────────────────────────────────────────
# Copy to `.env.local` for local dev, and set the same keys in Vercel.

# Which backend the data layer uses: "mock" (default, in-memory) or "supabase".
NEXT_PUBLIC_DATA_BACKEND=supabase

# From your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key — SERVER ONLY. Never expose to the browser, never prefix with
# NEXT_PUBLIC_. Used by API routes for writes (registration) and to grant Pro
# after a verified payment (required once monetization is switched on).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ── Monetization (Pro plan via Paystack) — OFF until you switch it on ─────────
# 1. Create a Paystack account → Settings → API Keys & Webhooks.
# 2. Set these (secret = SERVER ONLY).
# 3. Add a webhook in Paystack pointing to: https://www.anywork4me.com/api/paystack/webhook
# 4. Run supabase/migrations/0004_pro.sql, then flip
#    features.monetization.subscriptions = true in src/lib/config.ts and redeploy.
PAYSTACK_SECRET_KEY=sk_live_or_test_xxx
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_or_test_xxx

# ── Owner dashboard (/admin) ─────────────────────────────────────────────────
# Set this to lock the private dashboard to just you. Until it's set, /admin is
# reachable but shows a "secure me" banner. Pick a strong password.
ADMIN_PASSWORD=choose-a-strong-password
